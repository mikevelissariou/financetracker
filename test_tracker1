from typing import List, Dict
from models import Transaction, AccountSummary
from commands import FinanceCommand


class FinanceTracker:
    def __init__(self):
        self.transactions: List[Transaction] = []

    def run_command(self, command: FinanceCommand) -> None:
        command.execute(self)

    def _validate_transaction(self, transaction: Transaction) -> None:
        if transaction.transaction_type not in ("income", "expense"):
            raise ValueError("Transaction type must be 'income' or 'expense'.")  # check type

        if transaction.amount <= 0:
            raise ValueError("Transaction amount must be greater than zero.")  # check amount

        if transaction.category.strip() == "":
            raise ValueError("Transaction category cannot be blank.")  # check category

    def _add_transaction(self, transaction: Transaction) -> None:
        self._validate_transaction(transaction)
        self.transactions.append(transaction)  # add tx

    def _remove_last_transaction(self) -> None:
        if not self.transactions:
            raise ValueError("There are no transactions to remove.")  # empty check

        self.transactions.pop()  # remove last

    def get_summary(self) -> AccountSummary:
        total_income = 0.0
        total_expenses = 0.0

        for t in self.transactions:
            if t.transaction_type == "income":
                total_income += t.amount
            else:
                total_expenses += t.amount

        balance = total_income - total_expenses
        return AccountSummary(total_income, total_expenses, balance)

    def get_expenses_by_category(self) -> Dict[str, float]:
        totals: Dict[str, float] = {}

        for t in self.transactions:
            if t.transaction_type == "expense":
                if t.category not in totals:
                    totals[t.category] = 0.0
                totals[t.category] += t.amount

        return totals

    def list_transactions(self) -> List[Transaction]:
        return self.transactions.copy()  # copy list
